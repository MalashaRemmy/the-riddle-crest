rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =============================================
    // USER PROFILES
    // =============================================
    // Each user has a document at /users/{uid}
    // Only the authenticated owner can read/write their own profile.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // =============================================
      // GAME DATA (sub-collection)
      // =============================================
      // /users/{uid}/gameData/{docId}
      // Currently only one document: "progress"
      match /gameData/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
